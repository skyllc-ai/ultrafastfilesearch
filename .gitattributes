# Set the default behavior to automatically normalize line endings
* text=auto

# Explicitly define line endings for specific file types
*.rs text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.md text eol=lf

# Binary files should not have their line endings altered
*.png binary
*.jpg binary
*.gif binary
*.pdf binary
*.ico binary
*.svg binary

# Distribution binaries (platform-specific executables)
dist/**/*-macos-arm64 binary
dist/**/*-macos-intel binary
dist/**/*-linux-x64 binary
dist/**/*-linux-arm64 binary
dist/**/*-windows-x64.exe binary

