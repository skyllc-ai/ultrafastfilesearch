#
# REUSE ignore file
# Files and directories to exclude from REUSE compliance checking

# Generated files and build artifacts
target/
.git/
*.lock
Cargo.lock

# IDE and editor files
.idea.old/
.vscode/
*.swp
*.swo
*~

# Temporary and backup files
*.tmp
*.bak
*.backup.*
hybrid_error_example.long-type-*
src/app.rs.backup.*

# Database files (generated content)
*.sqlite
.qodo/

# Third-party and external files (JSON exports from external tools)
Insomnia & Postman/
SPDXLICENSES

# IDE configuration files (generated/user-specific)
.vscode/

# Build scripts (platform-specific)
build/*.bat
build/*.ps1
build/last_environment

# Git configuration files (already have headers)
scripts/.gitmessage

# Documentation that doesn't need headers
docs/rust_excellence.md

# Script parsing issues (sed commands confuse REUSE parser)
scripts/fix-legacy-headers.sh
scripts/complete-legal-compliance.sh
