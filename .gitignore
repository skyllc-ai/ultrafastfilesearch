metadata.json
.cargo/macos.toml
.cargo/windows.toml
.cargo/.zshrc

# =============================================================================
# Internal dev docs (plans, audits, investigations — local only)
# =============================================================================
/docs/dev/
/docs/research/
/docs/refactor/

# =============================================================================
# Explicit public-docs guard
# =============================================================================
# /docs/benchmarks/ is the public-facing competitive-benchmark hub — dated
# canonical reports, archive, hub README, reproduction scripts. This
# directory MUST stay tracked. The negation below is defensive: if a future
# gitignore rule ever matches /docs/benchmarks/* (e.g. someone adds
# /docs/*/ or a broader pattern), this keeps the hub checked in.
!/docs/benchmarks/
!/docs/benchmarks/**

# =============================================================================
# Local benchmark artifacts (never commit run output)
# =============================================================================
# Bench artifacts are consolidated under $UFFS_BENCH_DIR (default: a temp dir);
# these root-anchored rules are a defensive guard against stray in-repo writes
# from older bench runs / scripts.  Root-anchored (leading `/`) so they never
# touch the tracked `/docs/benchmarks/` hub above.
/benchmarks/
/out/bench/
/uffs_bench_out.csv
/bench_uffs_*.csv
/bench_cpp_*.csv
/bench_es_*.csv

# =============================================================================
# Local-only spec/prompt files
# =============================================================================
/prompts/
INTENT_PROMPT.md
INTENT_PROMPT_V2.md
INTENT_SPEC_FAANG_CORE_INFRA.mdconsole
crates/uffs-cli/console
