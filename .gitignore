# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Root clutter quarantine / local rollback staging
/_trash/*
!/_trash/.gitignore
/_trash/**/.gitkeep
/_trash/**/.keep

# Build artifacts and environment files
build/
build/last_environment

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk


# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Reference code (legacy C++ UFFS, boost, WTL, etc.)
reference/
!docs/reference/
docs/reference/**
!docs/reference/README.md

# Root-only clutter moved out of the tracked tree
/Shell/
/LOG/
/vendor/
/missing_paths.txt

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
.idea/

# JetBrains specific ignores
# Covers JetBrains IDEs: IntelliJ, RubyMine, PhpStorm, AppCode, PyCharm, CLion, Android Studio, WebStorm and Rider
# Reference: https://intellij-support.jetbrains.com/hc/en-us/articles/206544839

# User-specific stuff
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries
.idea/**/shelf

# AWS User-specific
.idea/**/aws.xml

# Generated files
.idea/**/contentModel.xml

# Sensitive or high-churn files
.idea/**/dataSources/
.idea/**/dataSources.ids
.idea/**/dataSources.local.xml
.idea/**/sqlDataSources.xml
.idea/**/dynamic.xml
.idea/**/uiDesigner.xml
.idea/**/dbnavigator.xml

# Gradle
.idea/**/gradle.xml
.idea/**/libraries

# Gradle and Maven with auto-import
# When using Gradle or Maven with auto-import, you should exclude module files,
# since they will be recreated, and may cause churn.  Uncomment if using
# auto-import.
# .idea/artifacts
# .idea/compiler.xml
# .idea/jarRepositories.xml
# .idea/mono_modules.xml
# .idea/*.iml
# .idea/mono_modules
# *.iml
# *.ipr

# CMake
cmake-build-*/

# Mongo Explorer plugin
.idea/**/mongoSettings.xml

# File-based project format
*.iws

# IntelliJ
out/

# mpeltonen/sbt-idea plugin
.idea_modules/

# JIRA plugin
atlassian-ide-plugin.xml

# Cursive Clojure plugin
.idea/replstate.xml

# SonarLint plugin
.idea/sonarlint/

# Crashlytics plugin (for Android Studio and IntelliJ)
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties

# Editor-based Rest Client
.idea/httpRequests

# Android studio 3.1+ serialized cache file
.idea/caches/build_file_checksums.ser

# OS specific ignores
# Windows specific
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS specific
.DS_Store
.AppleDouble
.LSOverride

# Linux specific
*~

.env
*.env

.env.sandbox


# Local environment files
.env.production

build/.ttapi-workflow-state.json
 .ttapi-workflow-state.json

# Cargo metadata output (machine-specific, auto-generated)
metadata.json

# Large trial run artifacts (can be very large, not for Git)
docs/trial_runs/

# Profiling bundles (contain large binaries and profile data)
bundles/

# Profile data (temporary, not for git)
docs/profiles/

# Personal/private files in LOG (keep CHANGELOG_HEALING.md files)
LOG/mental_health
LOG/projected_assessment_progression.md

# Vendor submodule dirty state (local build artifacts)
# The submodules themselves are tracked, but local modifications within them are ignored